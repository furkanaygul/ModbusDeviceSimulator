<Project Sdk="Microsoft.NET.Sdk">

  <PropertyGroup>
    <OutputType>Exe</OutputType>
    <TargetFramework>net9.0-windows</TargetFramework>
    <ImplicitUsings>enable</ImplicitUsings>
    <Nullable>enable</Nullable>
  </PropertyGroup>

  <ItemGroup>
    <Reference Include="System.IO.Ports">
      <HintPath>$(UserProfile)\.nuget\packages\system.io.ports\8.0.0\runtimes\win\lib\net8.0\System.IO.Ports.dll</HintPath>
      <Private>true</Private>
    </Reference>
  </ItemGroup>

  <Target Name="EnsureSystemIoPortsReference" BeforeTargets="ResolveReferences">
    <Error
      Condition="!Exists('$(UserProfile)\.nuget\packages\system.io.ports\8.0.0\runtimes\win\lib\net8.0\System.IO.Ports.dll')"
      Text="System.IO.Ports.dll bulunamadi. Gerekirse System.IO.Ports 8.0.0 paketini yeniden yukleyin." />
  </Target>

</Project>
